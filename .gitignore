# =========================
# BACKEND (Python / FastAPI)
# =========================
# Entornos virtuales (Si creas uno, Git lo ignorará)
venv/
env/
.env/

# Archivos compilados de Python
__pycache__/
*.pyc
*.pyo
*.pyd

# =========================
# FRONTEND (Vue / Node)
# =========================
# Dependencias de Node (¡Súper importante ignorar esto!)
frontend/node_modules/
node_modules/

# Archivos de construcción (cuando ejecutas npm run build)
frontend/dist/
dist/

# Logs de npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Caché de Firebase (ya que veo archivos de firebase en tu frontend)
.firebase/

# =========================
# GENERAL / OS / EDITORES
# =========================
# Archivos de entorno (contraseñas, tokens)
*.env
.env.local

# MacOS
.DS_Store

# Windows
Thumbs.db

# VS Code / IDEs
.vscode/
.idea/